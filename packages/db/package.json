{
    "name":  "@dcs/db",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "exports":  {
                    ".":  "./src/index.ts"
                },
    "dependencies":  {
                         "drizzle-orm":  "^0.39.1",
                         "pg":  "^8.14.1"
                     },
    "scripts":  {
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "db:generate":  "drizzle-kit generate --config drizzle.config.ts",
                    "db:migrate":  "drizzle-kit migrate --config drizzle.config.ts",
                    "seed":  "tsx src/seed.ts",
                    "reset":  "tsx src/reset.ts"
                }
}
